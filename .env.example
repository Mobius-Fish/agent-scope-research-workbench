# Choose one: deepseek | openai | openai_compatible
LLM_PROVIDER=deepseek

# For DeepSeek: use your DeepSeek key here. The code maps it to DEEPSEEK_API_KEY internally.
# For OpenAI: use your OpenAI key here.
# For OpenAI-compatible gateways: use your gateway key here.
LLM_API_KEY=

# DeepSeek recommended for this MVP:
# - deepseek-chat: better for structured JSON-like outputs
# - deepseek-reasoner: useful for reasoning, but not recommended for structured agent outputs in this MVP
LLM_MODEL_ID=deepseek-chat

# Only needed for LLM_PROVIDER=openai_compatible, e.g. a proxy/gateway/local OpenAI-compatible endpoint.
LLM_BASE_URL=

# Optional but recommended. If omitted, Tavily SDK may try keyless mode, which is rate-limited.
TAVILY_API_KEY=

# Runtime limits
MAX_TASKS=4
MAX_SEARCH_RESULTS=4
